{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "containerPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "required": [
        "port"
      ]
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      },
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ]
    },
    "existingSecretName": {
      "type": "string",
      "minLength": 1
    },
    "config": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "replicaCount",
    "containerPort",
    "service",
    "image",
    "existingSecretName",
    "config"
  ]
}
