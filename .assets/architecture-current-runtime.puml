@startuml
!pragma layout smetana
title AgenticNativePlatform - Runtime Flow With Flux Operator And Static Cluster Roots

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam wrapWidth 160
skinparam defaultTextAlignment center
hide stereotype

actor "External client" as Client
rectangle "Remote LLM providers\nGemini / OpenAI / Anthropic /\nBedrock / Vertex / others" as Providers
rectangle "Optional external LM Studio" as LMStudio

node "flux-system" {
  component "Flux Operator" as FluxOperator
  component "FluxInstance/flux" as FluxInstance
  component "GitRepository/platform" as GitRepository
  component "platform-infrastructure" as PlatformInfrastructure
  component "platform-secrets" as PlatformSecrets
  component "platform-runtime" as PlatformRuntime
  component "platform-applications" as PlatformApplications
  component "platform-applications-remotes" as PlatformApplicationsRemotes
  component "platform-applications-core" as PlatformApplicationsCore
}

node "Kubernetes cluster" {
  package "kgateway-system" {
    component "public-gateway" as PublicGateway
  }

  package "agentgateway-system" {
    component "agentgateway-llm-edge\nkgateway Backend" as AgentgatewayLlmEdge
    component "agentgateway-mcp-edge\nkgateway Backend" as AgentgatewayMcpEdge
    component "agentgateway-proxy-resiliency\nBackendConfigPolicy" as AgentgatewayProxyPolicy
    component "agentgateway-proxy" as AgentgatewayProxy
    component "litellm backend" as LitellmBackend
    component "tools MCP backend" as ToolsBackend
  }

  package "kagent" {
    component "kagent-controller" as KagentController
    component "kagent-ui" as KagentUI
    component "kagent-tools" as KagentTools
    component "k8s-agent" as K8sAgent
    component "kgateway-agent" as KGatewayAgent
    component "istio-agent" as IstioAgent
    component "promql-agent" as PromqlAgent
    component "observability-agent" as ObservabilityAgent
    component "argo-rollouts-agent" as ArgoRolloutsAgent
    component "helm-agent" as HelmAgent
    component "cilium-policy-agent" as CiliumPolicyAgent
    component "cilium-manager-agent" as CiliumManagerAgent
    component "cilium-debug-agent" as CiliumDebugAgent
    component "team-lead-agent-assist" as TeamLeadAgent
    component "grafana-mcp" as GrafanaMCP
    component "k8s-a2a-agent" as A2AAgent
    component "RemoteMCPServer" as RemoteMCP
  }

  package "agentregistry" {
    component "agentregistry-inventory" as Inventory
    component "DiscoveryConfig/local" as InventoryDiscovery
  }

  package "mcp-governance-system" {
    component "mcp-governance-controller" as MCPGController
    component "mcp-governance-dashboard" as MCPGDashboard
    component "MCPGovernancePolicy" as MCPGPolicy
    component "GovernanceEvaluation" as MCPGEvaluation
  }

  package "ai-gateway" {
    component "LiteLLM" as LiteLLM
  }

  package "ai-models" {
    component "tei-embeddings" as TEI
    component "KServe control plane" as KServe
    component "Ollama or vLLM\noptional runtime path" as RuntimeOverlay
  }

  package "context" {
    database "Qdrant" as Qdrant
    database "PostgreSQL" as Postgres
    database "Redis" as Redis
  }

  package "observability" {
    component "Prometheus" as Prometheus
    component "Grafana" as Grafana
    component "Loki" as Loki
    component "OpenTelemetry Collector" as OTelCollector
    component "Phoenix" as Phoenix
    component "Tempo" as Tempo
  }

  package "platform" {
    component "namespaces and wrappers\nfrom clusters/<topology>-<env>" as ClusterWrappers
  }
}

FluxOperator --> FluxInstance : lifecycle
FluxInstance --> GitRepository : sync
GitRepository --> PlatformInfrastructure
GitRepository --> PlatformSecrets
GitRepository --> PlatformRuntime
GitRepository --> PlatformApplications
PlatformInfrastructure --> PlatformRuntime : dependsOn
PlatformSecrets --> PlatformRuntime : dependsOn
PlatformRuntime --> PlatformApplications : dependsOn
PlatformSecrets --> PlatformApplications : dependsOn
PlatformApplications --> PlatformApplicationsRemotes : renders
PlatformApplications --> PlatformApplicationsCore : renders
PlatformApplicationsRemotes --> PlatformApplicationsCore : dependsOn
PlatformInfrastructure --> ClusterWrappers
PlatformInfrastructure --> Inventory : reconciles HelmRelease
PlatformInfrastructure --> MCPGController : reconciles HelmRelease
PlatformApplicationsCore --> MCPGPolicy : applies policy CR
PlatformApplicationsCore --> MCPGEvaluation : applies evaluation CR

Client --> PublicGateway : HTTP /v1 and /mcp
PublicGateway --> AgentgatewayLlmEdge : /v1
PublicGateway --> AgentgatewayMcpEdge : /mcp
AgentgatewayLlmEdge --> AgentgatewayProxy
AgentgatewayMcpEdge --> AgentgatewayProxy
AgentgatewayProxyPolicy --> AgentgatewayProxy : shared north-south resiliency

KagentUI --> KagentController : UI
A2AAgent --> KagentController : A2A
K8sAgent --> KagentController : Agent runtime
KGatewayAgent --> KagentController : Agent runtime
IstioAgent --> KagentController : Agent runtime
PromqlAgent --> KagentController : Agent runtime
ObservabilityAgent --> KagentController : Agent runtime
ArgoRolloutsAgent --> KagentController : Agent runtime
HelmAgent --> KagentController : Agent runtime
CiliumPolicyAgent --> KagentController : Agent runtime
CiliumManagerAgent --> KagentController : Agent runtime
CiliumDebugAgent --> KagentController : Agent runtime
TeamLeadAgent --> KagentController : Agent runtime
KagentController --> AgentgatewayProxy : /v1
RemoteMCP --> AgentgatewayProxy : /mcp/kagent-tools
Inventory --> InventoryDiscovery : default local discovery
Inventory --> KagentController : catalogs runtime resources
Inventory --> RemoteMCP : catalogs RemoteMCPServer
Inventory --> A2AAgent : catalogs Agents
MCPGEvaluation --> MCPGPolicy : policyRef
MCPGController --> MCPGPolicy : enforces checks
MCPGController --> MCPGEvaluation : runs evaluations
MCPGController --> AgentgatewayProxy : scans MCP gateway posture
MCPGController --> KagentController : scans agents and MCP resources
MCPGController --> Inventory : scans registry metadata

AgentgatewayProxy --> LitellmBackend : /v1
AgentgatewayProxy --> ToolsBackend : /mcp

LitellmBackend --> LiteLLM
ToolsBackend --> KagentTools

LiteLLM --> Redis : router state / cost scoring
LiteLLM --> Providers : default path
LiteLLM --> LMStudio : when enabled
LiteLLM --> RuntimeOverlay : optional local path
KServe .. RuntimeOverlay

KagentController --> TEI : embeddings
KagentController --> Qdrant : vectors
KagentController --> Postgres : state
KagentController --> Redis : cache
KagentController --> OTelCollector : traces
KagentTools --> OTelCollector : traces
GrafanaMCP --> Grafana : query Grafana API
GrafanaMCP --> OTelCollector : traces
AgentgatewayProxy --> OTelCollector : traces
OTelCollector --> Phoenix : OTLP gRPC
OTelCollector --> Tempo : OTLP gRPC
Prometheus --> GrafanaMCP : scrape /metrics via ServiceMonitor
Prometheus --> Grafana : metrics dashboards
Loki --> Grafana : logs
Tempo --> Grafana : traces
Phoenix --> Grafana : metrics via Prometheus

note top of FluxOperator
Flux lifecycle is managed by Flux Operator.
The sync entry point is a committed FluxInstance.
end note

note top of PlatformInfrastructure
The static cluster root under clusters/<topology>-<env>
fans out into staged Flux Kustomizations.
kgateway CRDs and controller readiness are checked here
before later runtime objects are allowed to apply.
end note

note top of AgentgatewayProxy
AgentGateway stays on the hot path.
/v1 enters through agentgateway-llm-edge and goes to LiteLLM.
/mcp enters through agentgateway-mcp-edge and goes to MCP backends.
end note

note bottom of LiteLLM
Default hot path:
kagent -> agentgateway -> LiteLLM -> provider
or optional local runtime
LiteLLM also uses Redis-backed router state
for shared routing and cost-scoring coordination.
end note

note bottom of Inventory
Internal-only by default.
UI and API are reached through port-forward.
Discovery catalogs local kagent resources,
including vendored agents and custom repo agents.
end note

note bottom of OTelCollector
Phoenix remains the AI-native trace view.
Tempo plus Prometheus plus Loki provide Grafana correlation.
The bundled grafana-mcp server now emits OTLP traces
and Prometheus metrics alongside kagent-tools.
end note

note bottom of MCPGController
Internal MCP governance control plane.
Dashboard is port-forwarded by default.
Policy and evaluation resources stay cluster-scoped.
end note

@enduml
