@startuml
!pragma layout smetana
title AgenticNativePlatform - Static GitOps Layout And Staged Cluster Composition

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam wrapWidth 160
skinparam defaultTextAlignment center
hide stereotype

actor "Operator" as Operator
rectangle "Remote Git repository\nGIT_REPO_URL @ GIT_BRANCH" as RemoteRepo

package "Repository source of truth" {
  component "clusters/" as RepoClusters
  component "infrastructure/" as RepoInfrastructure
  component "apps/" as RepoApps
  component "charts/\nrepo-local and vendored" as RepoCharts
  component "values/\nnon-secret only" as RepoValues
  component "secrets/\nSOPS roots by topology" as RepoSecrets
}

package "Shared platform integration example" {
  component "values/common/mcp-governance" as MCPGValues
  component "apps/platform/mcp-governance/core" as MCPGCore
  component "apps/platform/mcp-governance/resources" as MCPGResources
}

package "Local workstation bootstrap" {
  component "bootstrap-hosts" as BootstrapHosts
  component "local OCI cache\nhost-level pull-through" as LocalOciCache
  component "/etc/rancher/k3s/registries.yaml" as K3sRegistries
}

package "Committed cluster roots" {
  component "clusters/local-dev" as ClusterLocal
  component "clusters/github-codespace-dev" as ClusterCodespace
  component "clusters/minipc-dev" as ClusterMiniPC
  component "clusters/hybrid-dev" as ClusterHybrid
  component "clusters/hybrid-remote-dev" as ClusterHybridRemote
}

package "One cluster root" {
  component "flux-system/flux-instance.yaml" as ClusterFluxInstance
  component "infrastructure/\ncluster wrapper" as ClusterInfrastructure
  component "secrets/\ncluster wrapper" as ClusterSecrets
  component "runtime/\ncluster wrapper" as ClusterRuntime
  component "apps/\ncluster wrapper" as ClusterApps
}

node "flux-system" {
  component "Flux Operator" as FluxOperator
  component "FluxInstance/flux" as FluxInstance
  component "GitRepository/platform" as GitRepository
  component "platform-infrastructure" as PlatformInfrastructure
  component "platform-secrets" as PlatformSecrets
  component "platform-runtime" as PlatformRuntime
  component "platform-applications" as PlatformApplications
  component "platform-applications-remotes" as PlatformApplicationsRemotes
  component "platform-applications-core" as PlatformApplicationsCore
}

Operator --> RepoClusters : edit
Operator --> RepoInfrastructure : edit
Operator --> RepoApps : edit
Operator --> RepoCharts : edit
Operator --> RepoValues : edit
Operator --> RepoSecrets : edit
Operator --> RemoteRepo : commit and push
Operator --> BootstrapHosts : run for local topology

RepoClusters --> ClusterLocal
RepoClusters --> ClusterCodespace
RepoClusters --> ClusterMiniPC
RepoClusters --> ClusterHybrid
RepoClusters --> ClusterHybridRemote

ClusterLocal --> ClusterFluxInstance
ClusterLocal --> ClusterInfrastructure
ClusterLocal --> ClusterSecrets
ClusterLocal --> ClusterRuntime
ClusterLocal --> ClusterApps

FluxOperator --> FluxInstance : manages lifecycle
ClusterFluxInstance --> FluxInstance : rendered and applied
FluxInstance --> GitRepository : sync.kind=GitRepository
RemoteRepo --> GitRepository : remote source of truth

BootstrapHosts --> LocalOciCache : installs before k3s
BootstrapHosts --> K3sRegistries : renders mirror config
K3sRegistries --> LocalOciCache : localhost mirror endpoints

GitRepository --> PlatformInfrastructure
GitRepository --> PlatformSecrets
GitRepository --> PlatformRuntime
GitRepository --> PlatformApplications
PlatformInfrastructure --> PlatformRuntime : runtime needs controllers and CRDs
PlatformSecrets --> PlatformRuntime : runtime needs secrets
PlatformRuntime --> PlatformApplications : apps need runtime resources
PlatformSecrets --> PlatformApplications : apps need secrets

PlatformInfrastructure --> ClusterInfrastructure
PlatformSecrets --> ClusterSecrets
PlatformRuntime --> ClusterRuntime
PlatformApplications --> ClusterApps
PlatformApplications --> PlatformApplicationsRemotes : renders child stage
PlatformApplications --> PlatformApplicationsCore : renders child stage
PlatformApplicationsRemotes --> PlatformApplicationsCore : dependsOn

ClusterInfrastructure --> RepoInfrastructure
ClusterInfrastructure --> RepoCharts
ClusterInfrastructure --> RepoValues
ClusterSecrets --> RepoSecrets
ClusterRuntime --> RepoInfrastructure
ClusterRuntime --> RepoApps
ClusterApps --> RepoApps
RepoValues --> MCPGValues
RepoApps --> MCPGCore
RepoApps --> MCPGResources
PlatformInfrastructure --> MCPGValues : composes values ConfigMap
PlatformInfrastructure --> MCPGCore : composes HelmRelease
PlatformApplications --> MCPGResources : composes policy and evaluation

note bottom of RepoClusters
Committed cluster roots are now the GitOps
entrypoint for every topology.
end note

note bottom of RepoValues
values/ contains non-secret config only.
That keeps the layout OCI-ready.
end note

note bottom of PlatformApplications
Staging keeps controllers and CRDs ahead of
secrets, runtime resources, and dependent app objects.
The app wrapper now serializes remotes before core app resources.
end note

note bottom of RepoCharts
Vendored and repo-local Helm charts stay in Git so
Flux can package them from the same source of truth.
end note

note bottom of MCPGResources
MCP Governance is staged across infrastructure and applications:
Helm release first, then cluster-scoped policy resources.
end note

note bottom of LocalOciCache
Local topology only.
The cache lives outside the k3s data dir so repeated
cluster reinstalls can reuse image layers.
end note

@enduml
