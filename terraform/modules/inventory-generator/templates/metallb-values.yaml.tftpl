apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: primary-pool
  namespace: metallb-system
spec:
  addresses:
    - ${metallb_start}-${metallb_end}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: primary-pool
  namespace: metallb-system
spec:
  ipAddressPools:
    - primary-pool
