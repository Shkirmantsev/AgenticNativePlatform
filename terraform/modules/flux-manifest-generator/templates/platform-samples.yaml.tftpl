apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: platform-samples
  namespace: flux-system
spec:
  interval: 10m
  prune: true
  wait: true
  timeout: 10m
  suspend: ${enabled ? "false" : "true"}
  dependsOn:
    - name: ${depends_on_name}
  sourceRef:
    kind: GitRepository
    name: platform
  path: ${cluster_path}
