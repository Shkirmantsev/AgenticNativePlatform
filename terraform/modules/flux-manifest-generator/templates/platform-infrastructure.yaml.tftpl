apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: platform-infrastructure
  namespace: flux-system
spec:
  interval: 10m
  prune: true
  wait: true
  timeout: ${platform_infra_timeout}
  dependsOn:
    - name: platform-bootstrap
  sourceRef:
    kind: GitRepository
    name: platform
  path: ${cluster_path}
