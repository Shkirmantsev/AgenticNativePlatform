apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: platform-bootstrap
  namespace: flux-system
spec:
  interval: 10m
  prune: true
  wait: true
  timeout: ${platform_bootstrap_timeout}
  sourceRef:
    kind: GitRepository
    name: platform
  path: ${cluster_path}
%{ if secrets_mode == "sops" ~}
  decryption:
    provider: sops
    secretRef:
      name: sops-age
%{ endif ~}
