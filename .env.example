# Topology selection: local | minipc | hybrid | hybrid-remote
TOPOLOGY=local
ENV=dev

# SSH
SSH_USER=ubuntu
SSH_PRIVATE_KEY=~/.ssh/id_ed25519

# k3s
K3S_VERSION=v1.34.5+k3s1

#cluster.local is the standard internal Kubernetes DNS cluster domain used for
# service discovery
#Change it only when:
# you already have another cluster in the same environment using the same domain and you need strict separation
# you have special DNS requirements
# you intentionally want another internal suffix, for example:
# k8s.local
# corp.cluster
# lab.internal
CLUSTER_DOMAIN=cluster.local

# MetalLB pool for your LAN. Adjust to your network.
METALLB_START=192.168.1.240
METALLB_END=192.168.1.250

# Default domain or wildcard DNS if you have one.
# you need /etc/hosts
# At the beginning: yes, often that is the easiest option.
# For example, if your kgateway public IP becomes 192.168.1.241, add:
# 192.168.1.241 grafana.home.arpa
# 192.168.1.241 agents.home.arpa
# 192.168.1.241 llm.home.arpa
# Later you can move from /etc/hosts to:
# - your router’s local DNS
# - Pi-hole / AdGuard Home
# - dnsmasq / Unbound
# - real public DNS if you expose services externally
BASE_DOMAIN=home.arpa

# Default local host / LM Studio endpoint for the current workstation.
LOCAL_HOST_IP=192.168.1.108
LMSTUDIO_HOST_IP=192.168.1.108
LMSTUDIO_PORT=1234

# Flux
GIT_REPO_URL=https://github.com/Shkirmantsev/AgenticKubernatesNativePlatform-flux.git
GIT_BRANCH=main

# Google Gemini default starter provider
GOOGLE_API_KEY=replace-me
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
VERTEX_PROJECT_ID=
VERTEX_LOCATION=europe-west3
VERTEX_SERVICE_ACCOUNT_JSON_B64=

# Self-hosted runtime defaults
OLLAMA_DEFAULT_MODEL=qwen2.5:7b-instruct
#taken from the LM Studio API
EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b

# optional helper default for rendered Flux root
# RUNTIME=ollama → deploy the Ollama overlay,
#RUNTIME=none → deploy the vLLM/KServe overlay
#RUNTIME=remote-only → deploy the vLLM/KServe overlay
# hybrid mode → usually RUNTIME=vllm if you want at least one
# self-hosted model in cluster, plus Gemini as fallback/provider through LiteLLM
RUNTIME=none
