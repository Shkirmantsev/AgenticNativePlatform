# Topology selection: local | minipc | hybrid | hybrid-remote | github-workspace
TOPOLOGY=local
ENV=dev

# github-workspace is a Docker/k3d-based developer topology intended for GitHub
# Codespaces / workspaces and other ephemeral container-based environments.
# It does not use Terraform/Ansible host provisioning and does not depend on MetalLB.

# optional helper default for rendered Flux root
# RUNTIME=ollama → deploy the Ollama overlay,
#RUNTIME=none → deploy the vLLM/KServe overlay
#RUNTIME=remote-only → deploy the vLLM/KServe overlay
# hybrid mode → usually RUNTIME=vllm if you want at least one
# self-hosted model in cluster, plus Gemini as fallback/provider through LiteLLM
RUNTIME=none
LMSTUDIO_ENABLED=false
SECRETS_MODE=external
IAC_TOOL=tofu
PLATFORM_ENABLE_SAMPLES_ECHO_MCP=false

# Local workstation
LOCAL_HOST_IP=192.168.1.108
LOCAL_SSH_USER=dmytro

# miniPC and optional remote worker
MINIPC_IP=192.168.1.50
MINIPC_SSH_USER=ubuntu
REMOTE_WORKER_IP=192.168.1.60
REMOTE_WORKER_SSH_USER=ubuntu

# SSH private key used by Ansible for remote nodes
SSH_PRIVATE_KEY=~/.ssh/id_ed25519

# k3s
K3S_VERSION=v1.34.5+k3s1

#cluster.local is the standard internal Kubernetes DNS cluster domain used for
# service discovery
#Change it only when:
# you already have another cluster in the same environment using the same domain and you need strict separation
# you have special DNS requirements
# you intentionally want another internal suffix, for example:
# k8s.local
# corp.cluster
# lab.internal
CLUSTER_DOMAIN=cluster.local

# MetalLB pool for your LAN. Adjust to your network.
METALLB_START=192.168.1.240
METALLB_END=192.168.1.250

# Default domain or wildcard DNS if you have one.
# you need /etc/hosts
# At the beginning: yes, often that is the easiest option.
# For example, if your kgateway public IP becomes 192.168.1.241, add:
# 192.168.1.241 grafana.home.arpa
# 192.168.1.241 agents.home.arpa
# 192.168.1.241 llm.home.arpa
# Later you can move from /etc/hosts to:
# - your router’s local DNS
# - Pi-hole / AdGuard Home
# - dnsmasq / Unbound
# - real public DNS if you expose services externally
BASE_DOMAIN=home.arpa

# Remote Git repo used by Flux. This is currently the SAME repo
GIT_REPO_URL=https://github.com/Shkirmantsev/AgenticNativePlatform.git
GIT_BRANCH=main
FLUX_INSTANCE_SYNC_PATH=./flux/generated/clusters/local-dev-none-external

# Pinned Flux bootstrap versions used by the operator-based install flow.
FLUX_OPERATOR_VERSION=0.45.1
FLUX_VERSION=2.8.3

# Default starter provider: Google Gemini
GOOGLE_API_KEY=replace-me
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1
VERTEX_PROJECT_ID=
VERTEX_LOCATION=europe-west3
VERTEX_AI_API_KEY=
VERTEX_SERVICE_ACCOUNT_JSON_B64=

# LM Studio external OpenAI-compatible endpoint
LMSTUDIO_HOST_IP=192.168.1.108
LMSTUDIO_PORT=1234
LMSTUDIO_EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b
LMSTUDIO_CHAT_MODEL=qwen/qwen3-4b

# Embeddings and local model defaults
EMBEDDING_MODEL=onnx-models/all-MiniLM-L6-v2-onnx
OLLAMA_VERSION=v0.18.0
OLLAMA_DEFAULT_MODEL=qwen2.5:7b-instruct
VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
VLLM_CPU_KVCACHE_SPACE=2
VLLM_CPU_NUM_OF_RESERVED_CPU=1
VLLM_LD_PRELOAD=
VLLM_IMAGE=public.ecr.aws/q9t5s3a7/vllm-cpu-release-repo:v0.18.0
ECHO_MCP_IMAGE=echo-mcp:local

# Optional explicit credentials for generated external/SOPS secret flows.
# Leave empty to let the local render scripts create random values for internal-only components.
LITELLM_MASTER_KEY=
PLATFORM_POSTGRES_PASSWORD=
GRAFANA_ADMIN_USERNAME=admin
GRAFANA_ADMIN_PASSWORD=

# Optional age recipient for SOPS automation. Leave empty for the first external-secrets stage.
SOPS_AGE_RECIPIENT=
