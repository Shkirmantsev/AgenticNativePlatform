# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc
/.env
/.idea/.gitignore
/.idea/AgenticNativePlatform.iml
/.idea/checkstyle-idea.xml
/.idea/dbnavigator.xml
/.idea/misc.xml
/.idea/modules.xml
/.idea/vcs.xml

.env
*.auto.tfvars
terraform.tfvars
terraform.tfstate
terraform.tfstate.*
.terraform.lock.hcl
ansible/generated/
flux/generated/secrets/
.kube/generated/
.sops/
age.agekey
/ansible/inventory.iniflux/secrets/**/plaintext.yaml
/flux/secrets/dev/kagent-agentgateway.plaintext.yaml
/flux/secrets/dev/kagent-agentgateway.sops.yaml
/flux/secrets/dev/kustomization.yaml
/flux/secrets/dev/litellm-provider-secrets.plaintext.yaml
/flux/secrets/dev/litellm-provider-secrets.sops.yaml
/flux/secrets/dev/README.md
/flux/secrets/prod/kagent-agentgateway.plaintext.yaml
/flux/secrets/prod/kagent-agentgateway.sops.yaml
/flux/secrets/prod/kustomization.yaml
/flux/secrets/prod/litellm-provider-secrets.plaintext.yaml
/flux/secrets/prod/litellm-provider-secrets.sops.yaml
/flux/secrets/prod/README.md
/flux/secrets/stage/kagent-agentgateway.plaintext.yaml
/flux/secrets/stage/kagent-agentgateway.sops.yaml
/flux/secrets/stage/kustomization.yaml
/flux/secrets/stage/litellm-provider-secrets.plaintext.yaml
/flux/secrets/stage/litellm-provider-secrets.sops.yaml
/flux/secrets/stage/README.md
